module {
  func.func @concat_kernel_2d(%arg0: !pto.ptr<i16>, %arg1: !pto.ptr<i16>, %arg2: !pto.ptr<i16>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c16 = arith.constant 16 : index
    %c32 = arith.constant 32 : index
    %0 = pto.make_tensor_view %arg0, shape = [%c32, %c16], strides = [%c16, %c1] : !pto.tensor_view<?x?xi16>
    %1 = pto.make_tensor_view %arg1, shape = [%c32, %c16], strides = [%c16, %c1] : !pto.tensor_view<?x?xi16>
    %2 = pto.make_tensor_view %arg2, shape = [%c32, %c32], strides = [%c32, %c1] : !pto.tensor_view<?x?xi16>
    %3 = pto.partition_view %0, offsets = [%c0, %c0], sizes = [%c32, %c16] : !pto.tensor_view<?x?xi16> -> !pto.partition_tensor_view<32x16xi16>
    %4 = pto.partition_view %1, offsets = [%c0, %c0], sizes = [%c32, %c16] : !pto.tensor_view<?x?xi16> -> !pto.partition_tensor_view<32x16xi16>
    %5 = pto.partition_view %2, offsets = [%c0, %c0], sizes = [%c32, %c32] : !pto.tensor_view<?x?xi16> -> !pto.partition_tensor_view<32x32xi16>
    %6 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %7 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %8 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tload ins(%3 : !pto.partition_tensor_view<32x16xi16>) outs(%6 : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%4 : !pto.partition_tensor_view<32x16xi16>) outs(%7 : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tconcat ins(%6, %7 : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%8 : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tstore ins(%8 : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%5 : !pto.partition_tensor_view<32x32xi16>)
    return
  }
}

