module {
  func.func @binary_chain_f32_64x32(%in0: !pto.ptr<f32>, %out0: !pto.ptr<f32>) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c32 = arith.constant 32 : index
    %c64 = arith.constant 64 : index

    %in_tv = pto.make_tensor_view %in0, shape = [%c64, %c32] strides = [%c32, %c1] : !pto.tensor_view<?x?xf32>
    %out_tv = pto.make_tensor_view %out0, shape = [%c64, %c32] strides = [%c32, %c1] : !pto.tensor_view<?x?xf32>

    %in_pt = pto.partition_view %in_tv, offsets = [%c0, %c0], sizes = [%c64, %c32] : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<64x32xf32>
    %out_pt = pto.partition_view %out_tv, offsets = [%c0, %c0], sizes = [%c64, %c32] : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<64x32xf32>

    %a = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %b = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %c = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tload ins(%in_pt : !pto.partition_tensor_view<64x32xf32>) outs(%a : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tadd ins(%a, %a : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%b : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmul ins(%b, %a : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%c : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tstore ins(%c : !pto.tile_buf<loc=vec, dtype=f32, rows=64, cols=32, v_row=64, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%out_pt : !pto.partition_tensor_view<64x32xf32>)
    return
  }
}
