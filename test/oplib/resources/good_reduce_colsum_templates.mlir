      attributes {
        pto.oplib.kind = "l3_reduce_colsum_template",
        pto.oplib.entry_role = "variant",
        pto.oplib.op = "tcolsum",
        pto.oplib.variant_id = "binary",
        pto.oplib.match.dtype = "f32",
        pto.oplib.match.is_binary = true,
