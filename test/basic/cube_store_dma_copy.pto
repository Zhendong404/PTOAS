// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=pto-vpto-expand-bridge-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=ROUNDTRIP
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-after=pto-vpto-expand-bridge-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=EXPAND

module attributes {"pto.target_arch" = "a5"} {
  func.func @cube_store_dma_copy_probe(%src_mat: !pto.ptr<f16, mat>,
                                       %dst_ub: !pto.ptr<f16, ub>,
                                       %src_ub: !pto.ptr<f16, ub>,
                                       %dst_mat: !pto.ptr<f16, mat>) {
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c64_i64 = arith.constant 64 : i64

    pto.cube_store %src_mat, %dst_ub, %c16_i64
      nburst(%c1_i64, %c32_i64, %c64_i64)
      loop(%c1_i64, %c64_i64, %c32_i64)
      : !pto.ptr<f16, mat>, !pto.ptr<f16, ub>,
        i64, i64, i64, i64, loop i64, i64, i64

    pto.dma_copy %src_ub, %dst_mat, %c16_i64
      nburst(%c1_i64, %c32_i64, %c64_i64)
      : !pto.ptr<f16, ub>, !pto.ptr<f16, mat>,
        i64, i64, i64, i64

    return
  }

  func.func @cube_store_dma_copy_buffer_like_probe(
      %src_mat: memref<?xf16, #pto.address_space<mat>>,
      %dst_ub: memref<?xf16, #pto.address_space<vec>>,
      %src_ub: !pto.ptr<f16, ub>,
      %dst_mat: !pto.ptr<f16, mat>) {
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64
    %c64_i64 = arith.constant 64 : i64

    pto.cube_store %src_mat, %dst_ub, %c16_i64
      nburst(%c1_i64, %c32_i64, %c64_i64)
      loop(%c1_i64, %c64_i64, %c32_i64)
      : memref<?xf16, #pto.address_space<mat>>, memref<?xf16, #pto.address_space<vec>>,
        i64, i64, i64, i64, loop i64, i64, i64

    pto.dma_copy %src_ub, %dst_mat, %c16_i64
      nburst(%c1_i64, %c32_i64, %c64_i64)
      : !pto.ptr<f16, ub>, !pto.ptr<f16, mat>,
        i64, i64, i64, i64

    return
  }

  func.func @cube_load_probe(%src_gm: !pto.ptr<f16, gm>,
                             %dst_mat: !pto.ptr<f16, mat>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.cube_load %src_gm, %dst_mat, %c16_i64
      nburst(%c1_i64, %c0_i64, %c32_i64)
      : !pto.ptr<f16, gm>, !pto.ptr<f16, mat>,
        i64, i64, i64, i64

    return
  }

  func.func @cube_load_buffer_like_probe(
      %src_gm: memref<?xf16, #pto.address_space<gm>>,
      %dst_mat: memref<?xf16, #pto.address_space<mat>>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.cube_load %src_gm, %dst_mat, %c16_i64
      nburst(%c1_i64, %c0_i64, %c32_i64)
      : memref<?xf16, #pto.address_space<gm>>, memref<?xf16, #pto.address_space<mat>>,
        i64, i64, i64, i64

    return
  }
}

// ROUNDTRIP-DAG: func.func @cube_load_probe(%{{.*}}: !pto.ptr<f16, gm>, %{{.*}}: !pto.ptr<f16, mat>) {
// ROUNDTRIP-DAG: func.func @cube_store_dma_copy_buffer_like_probe(%{{.*}}: !pto.ptr<f16, mat>, %{{.*}}: !pto.ptr<f16, ub>, %{{.*}}: !pto.ptr<f16, ub>, %{{.*}}: !pto.ptr<f16, mat>) {
// ROUNDTRIP-DAG: func.func @cube_store_dma_copy_probe(%{{.*}}: !pto.ptr<f16, mat>, %{{.*}}: !pto.ptr<f16, ub>, %{{.*}}: !pto.ptr<f16, ub>, %{{.*}}: !pto.ptr<f16, mat>) {
// ROUNDTRIP-DAG: func.func @cube_load_buffer_like_probe(%{{.*}}: !pto.ptr<f16, gm>, %{{.*}}: !pto.ptr<f16, mat>) {
// ROUNDTRIP-DAG: pto.cube_store %{{.*}}, %{{.*}}, %{{.*}} nburst(%{{.*}}, %{{.*}}, %{{.*}}) loop(%{{.*}}, %{{.*}}, %{{.*}})
// ROUNDTRIP-DAG: pto.dma_copy %{{.*}}, %{{.*}}, %{{.*}} nburst(%{{.*}}, %{{.*}}, %{{.*}})
// ROUNDTRIP-DAG: pto.cube_load %{{.*}}, %{{.*}}, %{{.*}} nburst(%{{.*}}, %{{.*}}, %{{.*}})

// EXPAND-DAG: func.func @cube_load_probe(
// EXPAND-DAG: func.func @cube_load_buffer_like_probe(
// EXPAND-DAG: func.func @cube_store_dma_copy_probe(
// EXPAND-DAG: func.func @cube_store_dma_copy_buffer_like_probe(
// EXPAND-DAG: pto.copy_gm_to_cbuf
// EXPAND-DAG: scf.for
// EXPAND-DAG: pto.copy_cbuf_to_ubuf
// EXPAND-DAG: pto.copy_ubuf_to_cbuf
