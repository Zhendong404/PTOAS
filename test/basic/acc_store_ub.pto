// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=pto-vpto-expand-bridge-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=ROUNDTRIP
// RUN: ptoas --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-after=pto-vpto-expand-bridge-ops %s -o /dev/null 2>&1 | FileCheck %s --check-prefix=EXPAND

module attributes {"pto.target_arch" = "a5"} {
  func.func @acc_store_ub_probe(%src: !pto.ptr<f32, acc>,
                                %dst: !pto.ptr<f32, ub>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c2_i64 = arith.constant 2 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.acc_store_ub %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64,
      %c0_i64, %c0_i64, %c0_i64, %c0_i64, %c1_i64, nz2nd
      loop3(%c1_i64, %c0_i64, %c32_i64)
      : !pto.ptr<f32, acc>, !pto.ptr<f32, ub>,
        i64, i64, i64, i64, i64, i64,
        i64, i64, i64, nz2nd, loop3 i64, i64, i64

    pto.acc_store_ub %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64,
      %c0_i64, %c0_i64, %c0_i64, %c2_i64, %c0_i64, nz2nz(%c1_i64)
      : !pto.ptr<f32, acc>, !pto.ptr<f32, ub>,
        i64, i64, i64, i64, i64, i64,
        i64, i64, i64, nz2nz(i64)

    return
  }

  func.func @acc_store_ub_buffer_like_probe(
      %src: memref<?xf32, #pto.address_space<acc>>,
      %dst: memref<?xf32, #pto.address_space<vec>>) {
    %c0_i64 = arith.constant 0 : i64
    %c1_i64 = arith.constant 1 : i64
    %c2_i64 = arith.constant 2 : i64
    %c16_i64 = arith.constant 16 : i64
    %c32_i64 = arith.constant 32 : i64

    pto.acc_store_ub %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64,
      %c0_i64, %c0_i64, %c0_i64, %c0_i64, %c1_i64, nz2nd
      loop3(%c1_i64, %c0_i64, %c32_i64)
      : memref<?xf32, #pto.address_space<acc>>, memref<?xf32, #pto.address_space<vec>>,
        i64, i64, i64, i64, i64, i64,
        i64, i64, i64, nz2nd, loop3 i64, i64, i64

    pto.acc_store_ub %src, %dst, %c16_i64, %c16_i64, %c16_i64, %c32_i64,
      %c0_i64, %c0_i64, %c0_i64, %c2_i64, %c0_i64, nz2nz(%c1_i64)
      : memref<?xf32, #pto.address_space<acc>>, memref<?xf32, #pto.address_space<vec>>,
        i64, i64, i64, i64, i64, i64,
        i64, i64, i64, nz2nz(i64)

    return
  }
}

// ROUNDTRIP-DAG: func.func @acc_store_ub_probe(%{{.*}}: !pto.ptr<f32, acc>, %{{.*}}: !pto.ptr<f32, ub>) {
// ROUNDTRIP-DAG: func.func @acc_store_ub_buffer_like_probe(%{{.*}}: !pto.ptr<f32, acc>, %{{.*}}: !pto.ptr<f32, ub>) {
// ROUNDTRIP-DAG: pto.acc_store_ub %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, nz2nd loop3(%{{.*}}, %{{.*}}, %{{.*}})
// ROUNDTRIP-DAG: pto.acc_store_ub %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, %{{.*}}, nz2nz(%{{.*}})

// EXPAND-DAG: func.func @acc_store_ub_probe(
// EXPAND-DAG: func.func @acc_store_ub_buffer_like_probe(
// EXPAND-DAG: pto.set_loop3_para
// EXPAND-DAG: pto.set_channel_para
// EXPAND-DAG: pto.copy_matrix_cc_to_ub
