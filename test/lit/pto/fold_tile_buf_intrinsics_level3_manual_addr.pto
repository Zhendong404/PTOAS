// RUN: ptoas --pto-level=level3 --pto-arch=a5 --pto-backend=vpto --emit-vpto --mlir-print-ir-before=pto-expand-tile-op --mlir-print-ir-after=pto-fold-tile-buf-intrinsics %s -o /dev/null 2>&1 | FileCheck %s

// CHECK: IR Dump Before ExpandTileOp
// CHECK-LABEL: func.func @manual_addr_tadd
// CHECK-DAG: %c1024_i64 = arith.constant 1024 : i64
// CHECK-DAG: %c2048_i64 = arith.constant 2048 : i64
// CHECK-DAG: %c4096_i64 = arith.constant 4096 : i64
// CHECK: pto.alloc_tile addr = %c1024_i64
// CHECK: pto.alloc_tile addr = %c2048_i64
// CHECK: pto.alloc_tile addr = %c4096_i64
// CHECK: pto.tadd ins(
// CHECK-NOT: memref<
// CHECK: IR Dump After FoldTileBufIntrinsics

// CHECK-LABEL: func.func @manual_addr_tadd
// CHECK-NOT: pto.tile_buf_addr
// CHECK-NOT: pto.tile_valid_rows
// CHECK-NOT: pto.tile_valid_cols
// CHECK-DAG: pto.castptr %c1024_i64 : i64 -> !pto.ptr<f32, ub>
// CHECK-DAG: pto.castptr %c2048_i64 : i64 -> !pto.ptr<f32, ub>
// CHECK-DAG: pto.castptr %c4096_i64 : i64 -> !pto.ptr<f32, ub>
// CHECK: arith.constant 16 : index
// CHECK: arith.constant 64 : index
// CHECK: pto.vlds
// CHECK: pto.vadd
// CHECK: pto.vsts

module {
  func.func @manual_addr_tadd() {
    %a_addr = arith.constant 1024 : i64
    %b_addr = arith.constant 2048 : i64
    %dst_addr = arith.constant 4096 : i64
    %a = pto.alloc_tile addr = %a_addr
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %b = pto.alloc_tile addr = %b_addr
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %dst = pto.alloc_tile addr = %dst_addr
      : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tadd ins(%a, %b : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                             blayout=row_major, slayout=none_box, fractal=512, pad=0>,
                         !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                             blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             outs(%dst : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=64, v_row=16, v_col=64,
                                  blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}
