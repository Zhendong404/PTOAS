// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level2 --enable-op-fusion --emit-pto-ir %s -o - | FileCheck %s --check-prefix=SEAM
// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level2 --enable-op-fusion --enable-insert-sync --emit-pto-ir %s -o - | FileCheck %s --check-prefix=SYNC
// RUN: ptoas --pto-backend=vpto --pto-arch=a5 --pto-level=level2 --enable-op-fusion --emit-vpto %s --mlir-print-ir-after=pto-expand-tile-op -o /dev/null 2>&1 | FileCheck %s --check-prefix=EXPAND
//
// Level2 adapter placement regression:
//   1. The shared fusion core runs before PlanMemory, so the seam IR still
//      contains pto.fusion_region after PlanMemory rewrites local tiles to
//      pointer_cast bindings.
//   2. Optional PTOInsertSync stays after the fused region and only appends the
//      tail barrier in the seam IR.
//   3. ExpandTileOp runs later and preserves the fusion_region wrapper while
//      replacing tile ops with TileLang helper calls.

module {
  func.func @fusion_adapter_placement_level2_tadd() {
    %a = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %b = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %c = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %d = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tmp0 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tmp1 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %out = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tadd ins(%a, %b : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%tmp0 : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tadd ins(%c, %d : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%tmp1 : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tadd ins(%tmp0, %tmp1 : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%out : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    return
  }
}

// SEAM-LABEL: func.func @fusion_adapter_placement_level2_tadd() {
// SEAM: %0 = pto.pointer_cast(%c20480_i64)
// SEAM: %1 = pto.pointer_cast(%c16384_i64)
// SEAM: %2 = pto.pointer_cast(%c12288_i64)
// SEAM: %3 = pto.pointer_cast(%c8192_i64)
// SEAM: pto.fusion_region {
// SEAM: %4 = pto.pointer_cast(%c0_i64)
// SEAM: %5 = pto.pointer_cast(%c4096_i64)
// SEAM: %6 = pto.pointer_cast(%c8192_i64)
// SEAM: pto.tadd ins(%0, %1
// SEAM-NEXT: pto.tadd ins(%2, %3
// SEAM-NEXT: pto.tadd ins(%4, %5
// SEAM-NEXT: pto.yield() : () -> ()
// SEAM: return

// SYNC-LABEL: func.func @fusion_adapter_placement_level2_tadd() {
// SYNC: pto.fusion_region {
// SYNC: pto.yield() : () -> ()
// SYNC: } {pto.fusion.group_id = 0 : i64} :
// SYNC-NEXT: pto.barrier <PIPE_ALL> {pto.auto_sync_tail_barrier}
// SYNC-NEXT: return

// EXPAND: // -----// IR Dump After ExpandTileOp (pto-expand-tile-op) //----- //
// EXPAND-LABEL: func.func @fusion_adapter_placement_level2_tadd() {
// EXPAND: pto.fusion_region {
// EXPAND: %4 = pto.pointer_cast(%c0_i64)
// EXPAND: %5 = pto.pointer_cast(%c4096_i64)
// EXPAND: func.call @__pto_tilelang_a5_tadd
// EXPAND: func.call @__pto_tilelang_a5_tadd
// EXPAND: func.call @__pto_tilelang_a5_tadd
// EXPAND-NOT: pto.tadd ins(
// EXPAND: pto.yield() : () -> ()
