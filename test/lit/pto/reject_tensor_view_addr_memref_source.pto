// RUN: not ptoas --pto-level=level3 --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - 2>&1 | FileCheck %s

// CHECK: tensor_view_addr
// CHECK: TensorViewLike

module {
  func.func @reject_tensor_view_addr_memref_source(%m: memref<16x64xf32>)
      -> !pto.ptr<f32> {
    %addr = pto.tensor_view_addr %m
      : memref<16x64xf32> -> !pto.ptr<f32>
    return %addr : !pto.ptr<f32>
  }
}
