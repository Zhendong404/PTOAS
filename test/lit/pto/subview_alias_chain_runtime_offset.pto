// RUN: ptoas %s 2>&1 | FileCheck %s

module {
  func.func @subview_alias_chain_runtime_offset(
      %src: !pto.ptr<f16>,
      %dst: !pto.ptr<i16>) {
    %c0_src = arith.constant 0 : index
    %c32_src_0 = arith.constant 32 : index
    %c32_src_1 = arith.constant 32 : index
    %c32_src_s0 = arith.constant 32 : index
    %c1_src_s1 = arith.constant 1 : index
    %src_tv = pto.make_tensor_view %src, shape = [%c32_src_0, %c32_src_1], strides = [%c32_src_s0, %c1_src_s1] : !pto.tensor_view<32x32xf16>
    %src_pt = pto.partition_view %src_tv, offsets = [%c0_src, %c0_src], sizes = [%c32_src_0, %c32_src_1] : !pto.tensor_view<32x32xf16> -> !pto.partition_tensor_view<32x32xf16>
    %c0_dst = arith.constant 0 : index
    %c32_dst_0 = arith.constant 32 : index
    %c16_dst_1 = arith.constant 16 : index
    %c16_dst_s0 = arith.constant 16 : index
    %c1_dst_s1 = arith.constant 1 : index
    %dst_tv = pto.make_tensor_view %dst, shape = [%c32_dst_0, %c16_dst_1], strides = [%c16_dst_s0, %c1_dst_s1] : !pto.tensor_view<32x16xi16>
    %dst_pt = pto.partition_view %dst_tv, offsets = [%c0_dst, %c0_dst], sizes = [%c32_dst_0, %c16_dst_1] : !pto.tensor_view<32x16xi16> -> !pto.partition_tensor_view<32x16xi16>
    %c0 = arith.constant 0 : index
    %c16 = arith.constant 16 : index

    %base = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tload ins(%src_pt : !pto.partition_tensor_view<32x32xf16>)
             outs(%base : !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    %sub = pto.subview %base[%c16, %c0] sizes [16, 32] :
      !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %reshape = pto.treshape %sub
      : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=32, v_row=16, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>
        -> !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %cast = pto.bitcast %reshape
      : !pto.tile_buf<loc=vec, dtype=f16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
        -> !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tstore ins(%cast : !pto.tile_buf<loc=vec, dtype=i16, rows=32, cols=16, v_row=32, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%dst_pt : !pto.partition_tensor_view<32x16xi16>)
    return
  }
}

// CHECK-DAG: const int32_t [[LINEAR:v[0-9]+]] = 512;
// CHECK-DAG: const int32_t [[ELEMSZ:v[0-9]+]] = 2;
// CHECK: Tile<TileType::Vec, half, 32, 16, BLayout::RowMajor, 32, 16, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null> {{v[0-9]+}};
// CHECK: Tile<TileType::Vec, int16_t, 32, 16, BLayout::RowMajor, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null> {{v[0-9]+}};
// CHECK: TSTORE(
