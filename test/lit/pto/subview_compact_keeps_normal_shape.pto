// RUN: ptoas %s 2>&1 | FileCheck %s

module {
  func.func @subview_compact_keeps_normal_shape(
      %src: !pto.ptr<f32>,
      %dst: !pto.ptr<f32>) {
    %c0_src = arith.constant 0 : index
    %c16_src_0 = arith.constant 16 : index
    %c16_src_1 = arith.constant 16 : index
    %c16_src_s0 = arith.constant 16 : index
    %c1_src_s1 = arith.constant 1 : index
    %src_tv = pto.make_tensor_view %src, shape = [%c16_src_0, %c16_src_1], strides = [%c16_src_s0, %c1_src_s1] : !pto.tensor_view<16x16xf32>
    %src_pt = pto.partition_view %src_tv, offsets = [%c0_src, %c0_src], sizes = [%c16_src_0, %c16_src_1] : !pto.tensor_view<16x16xf32> -> !pto.partition_tensor_view<16x16xf32>
    %c0_dst = arith.constant 0 : index
    %c8_dst_0 = arith.constant 8 : index
    %c16_dst_1 = arith.constant 16 : index
    %c16_dst_s0 = arith.constant 16 : index
    %c1_dst_s1 = arith.constant 1 : index
    %dst_tv = pto.make_tensor_view %dst, shape = [%c8_dst_0, %c16_dst_1], strides = [%c16_dst_s0, %c1_dst_s1] : !pto.tensor_view<8x16xf32>
    %dst_pt = pto.partition_view %dst_tv, offsets = [%c0_dst, %c0_dst], sizes = [%c8_dst_0, %c16_dst_1] : !pto.tensor_view<8x16xf32> -> !pto.partition_tensor_view<8x16xf32>
    %c0 = arith.constant 0 : index

    %tile = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tload ins(%src_pt : !pto.partition_tensor_view<16x16xf32>)
             outs(%tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    %s0 = pto.subview %tile[%c0, %c0] sizes [8, 16] :
      !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tstore ins(%s0 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%dst_pt : !pto.partition_tensor_view<8x16xf32>)
    return
  }
}

// CHECK: Tile<TileType::Vec, float, 8, 16, BLayout::RowMajor, 8, 16, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null>
// CHECK-NOT: Tile<TileType::Vec, float, 16, 16, BLayout::RowMajor, 8, 16, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null>
