// RUN: ptoas %s 2>&1 | FileCheck %s

module {
  func.func @tilebuf_root_trace(%arg0: !pto.ptr<f16>,
                                %arg1: !pto.ptr<i16>) {
    %c0_arg0 = arith.constant 0 : index
    %c16_arg0_0 = arith.constant 16 : index
    %c16_arg0_1 = arith.constant 16 : index
    %c16_arg0_s0 = arith.constant 16 : index
    %c1_arg0_s1 = arith.constant 1 : index
    %arg0_tv = pto.make_tensor_view %arg0, shape = [%c16_arg0_0, %c16_arg0_1], strides = [%c16_arg0_s0, %c1_arg0_s1] : !pto.tensor_view<16x16xf16>
    %arg0_pt = pto.partition_view %arg0_tv, offsets = [%c0_arg0, %c0_arg0], sizes = [%c16_arg0_0, %c16_arg0_1] : !pto.tensor_view<16x16xf16> -> !pto.partition_tensor_view<16x16xf16>
    %c0_arg1 = arith.constant 0 : index
    %c16_arg1_0 = arith.constant 16 : index
    %c16_arg1_1 = arith.constant 16 : index
    %c16_arg1_s0 = arith.constant 16 : index
    %c1_arg1_s1 = arith.constant 1 : index
    %arg1_tv = pto.make_tensor_view %arg1, shape = [%c16_arg1_0, %c16_arg1_1], strides = [%c16_arg1_s0, %c1_arg1_s1] : !pto.tensor_view<16x16xi16>
    %arg1_pt = pto.partition_view %arg1_tv, offsets = [%c0_arg1, %c0_arg1], sizes = [%c16_arg1_0, %c16_arg1_1] : !pto.tensor_view<16x16xi16> -> !pto.partition_tensor_view<16x16xi16>
    %c0 = arith.constant 0 : index

    %base = pto.alloc_tile
      : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %sub = pto.subview %base[%c0, %c0] sizes [16, 16] :
      !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                    blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                       blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %cast = pto.bitcast %sub
      : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                      blayout=row_major, slayout=none_box, fractal=512, pad=0>
        -> !pto.tile_buf<loc=vec, dtype=i16, rows=16, cols=16, v_row=16, v_col=16,
                         blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tload ins(%arg0_pt : !pto.partition_tensor_view<16x16xf16>)
             outs(%base : !pto.tile_buf<loc=vec, dtype=f16, rows=16, cols=16, v_row=16, v_col=16,
                                        blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tstore ins(%cast : !pto.tile_buf<loc=vec, dtype=i16, rows=16, cols=16, v_row=16, v_col=16,
                                      blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%arg1_pt : !pto.partition_tensor_view<16x16xi16>)
    return
  }
}

// CHECK: __global__ AICORE void tilebuf_root_trace
// CHECK: Tile<TileType::Vec, half, 16, 16, BLayout::RowMajor, 16, 16, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null> {{v[0-9]+}};
// CHECK: Tile<TileType::Vec, int16_t, 16, 16, BLayout::RowMajor, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null> {{v[0-9]+}};
// CHECK: reinterpret_cast<uint64_t>
// CHECK: TSTORE(
