// RUN: ptoas --pto-arch a5 --enable-insert-sync %s | FileCheck %s --check-prefix=A5
// RUN: ptoas --pto-arch a3 %s | FileCheck %s --check-prefix=A3

module attributes {"pto.device-spec" = "Ascend950"} {
  func.func @tmov_acc_to_vec_mode_a5(%a: !pto.ptr<f16>,
                                     %b: !pto.ptr<f16>) {
    %c0_a = arith.constant 0 : index
    %c32_a_0 = arith.constant 32 : index
    %c32_a_1 = arith.constant 32 : index
    %c32_a_s0 = arith.constant 32 : index
    %c1_a_s1 = arith.constant 1 : index
    %a_tv = pto.make_tensor_view %a, shape = [%c32_a_0, %c32_a_1], strides = [%c32_a_s0, %c1_a_s1] : !pto.tensor_view<32x32xf16>
    %a_pt = pto.partition_view %a_tv, offsets = [%c0_a, %c0_a], sizes = [%c32_a_0, %c32_a_1] : !pto.tensor_view<32x32xf16> -> !pto.partition_tensor_view<32x32xf16>
    %c0_b = arith.constant 0 : index
    %c32_b_0 = arith.constant 32 : index
    %c32_b_1 = arith.constant 32 : index
    %c32_b_s0 = arith.constant 32 : index
    %c1_b_s1 = arith.constant 1 : index
    %b_tv = pto.make_tensor_view %b, shape = [%c32_b_0, %c32_b_1], strides = [%c32_b_s0, %c1_b_s1] : !pto.tensor_view<32x32xf16>
    %b_pt = pto.partition_view %b_tv, offsets = [%c0_b, %c0_b], sizes = [%c32_b_0, %c32_b_1] : !pto.tensor_view<32x32xf16> -> !pto.partition_tensor_view<32x32xf16>
    %a_mat = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %b_mat = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>
    %a_left = pto.alloc_tile : !pto.tile_buf<loc=left, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>
    %b_right = pto.alloc_tile : !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>
    %acc = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    %dst_vec = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tload ins(%a_pt : !pto.partition_tensor_view<32x32xf16>)
              outs(%a_mat : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
    pto.tload ins(%b_pt : !pto.partition_tensor_view<32x32xf16>)
              outs(%b_mat : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
    pto.tmov ins(%a_mat : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
             outs(%a_left : !pto.tile_buf<loc=left, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>)
    pto.tmov ins(%b_mat : !pto.tile_buf<loc=mat, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=512, pad=0>)
             outs(%b_right : !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>)
    pto.tmatmul ins(%a_left, %b_right : !pto.tile_buf<loc=left, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=row_major, fractal=512, pad=0>,
                                        !pto.tile_buf<loc=right, dtype=f16, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=col_major, fractal=512, pad=0>)
                outs(%acc : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
    pto.tmov ins(%acc : !pto.tile_buf<loc=acc, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=col_major, slayout=row_major, fractal=1024, pad=0>)
             outs(%dst_vec : !pto.tile_buf<loc=vec, dtype=f32, rows=32, cols=32, v_row=32, v_col=32, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
             {accToVecMode = #pto.acc_to_vec_mode<dual_mode_split_m>}
    return
  }
}

// A5-LABEL: __global__ AICORE void tmov_acc_to_vec_mode_a5(
// A5: set_flag(PIPE_M, PIPE_FIX, EVENT_ID0);
// A5: wait_flag(PIPE_M, PIPE_FIX, EVENT_ID0);
// A5: TMOV<{{.*}}pto::AccToVecMode::DualModeSplitM{{.*}}>(
// A3-LABEL: __global__ AICORE void tmov_acc_to_vec_mode_a5(
// A3: TMOV<{{.*}}pto::AccToVecMode::DualModeSplitM{{.*}}>(
