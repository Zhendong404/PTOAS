// RUN: not ptoas --pto-level=level3 --pto-arch=a5 --pto-backend=vpto --emit-vpto %s -o - 2>&1 | FileCheck %s

// CHECK: FoldTileBufIntrinsics: memref-sourced tensor_view bridge is not supported
// CHECK: expected native pto.make_tensor_view / pto.partition_view producer

module {
  func.func @old_memref_to_tensorview_bridge(%m: memref<16x64xf32>) -> index {
    %c0 = arith.constant 0 : index
    %tv = builtin.unrealized_conversion_cast %m
      : memref<16x64xf32> to !pto.tensor_view<16x64xf32>
    %dim = pto.get_tensor_view_dim %tv, %c0
      : !pto.tensor_view<16x64xf32> -> index
    return %dim : index
  }
}
