// RUN: ptoas %s 2>&1 | FileCheck %s

module {
  func.func @subview_bind_tile_preserve_stride(
      %src: !pto.ptr<f32>,
      %dst0: !pto.ptr<f32>,
      %dst1: !pto.ptr<f32>,
      %dst2: !pto.ptr<f32>,
      %dst3: !pto.ptr<f32>) {
    %c0_src = arith.constant 0 : index
    %c16_src_0 = arith.constant 16 : index
    %c16_src_1 = arith.constant 16 : index
    %c16_src_s0 = arith.constant 16 : index
    %c1_src_s1 = arith.constant 1 : index
    %src_tv = pto.make_tensor_view %src, shape = [%c16_src_0, %c16_src_1], strides = [%c16_src_s0, %c1_src_s1] : !pto.tensor_view<16x16xf32>
    %src_pt = pto.partition_view %src_tv, offsets = [%c0_src, %c0_src], sizes = [%c16_src_0, %c16_src_1] : !pto.tensor_view<16x16xf32> -> !pto.partition_tensor_view<16x16xf32>
    %c0_dst0 = arith.constant 0 : index
    %c8_dst0_0 = arith.constant 8 : index
    %c8_dst0_1 = arith.constant 8 : index
    %c8_dst0_s0 = arith.constant 8 : index
    %c1_dst0_s1 = arith.constant 1 : index
    %dst0_tv = pto.make_tensor_view %dst0, shape = [%c8_dst0_0, %c8_dst0_1], strides = [%c8_dst0_s0, %c1_dst0_s1] : !pto.tensor_view<8x8xf32>
    %dst0_pt = pto.partition_view %dst0_tv, offsets = [%c0_dst0, %c0_dst0], sizes = [%c8_dst0_0, %c8_dst0_1] : !pto.tensor_view<8x8xf32> -> !pto.partition_tensor_view<8x8xf32>
    %c0_dst1 = arith.constant 0 : index
    %c8_dst1_0 = arith.constant 8 : index
    %c8_dst1_1 = arith.constant 8 : index
    %c8_dst1_s0 = arith.constant 8 : index
    %c1_dst1_s1 = arith.constant 1 : index
    %dst1_tv = pto.make_tensor_view %dst1, shape = [%c8_dst1_0, %c8_dst1_1], strides = [%c8_dst1_s0, %c1_dst1_s1] : !pto.tensor_view<8x8xf32>
    %dst1_pt = pto.partition_view %dst1_tv, offsets = [%c0_dst1, %c0_dst1], sizes = [%c8_dst1_0, %c8_dst1_1] : !pto.tensor_view<8x8xf32> -> !pto.partition_tensor_view<8x8xf32>
    %c0_dst2 = arith.constant 0 : index
    %c8_dst2_0 = arith.constant 8 : index
    %c8_dst2_1 = arith.constant 8 : index
    %c8_dst2_s0 = arith.constant 8 : index
    %c1_dst2_s1 = arith.constant 1 : index
    %dst2_tv = pto.make_tensor_view %dst2, shape = [%c8_dst2_0, %c8_dst2_1], strides = [%c8_dst2_s0, %c1_dst2_s1] : !pto.tensor_view<8x8xf32>
    %dst2_pt = pto.partition_view %dst2_tv, offsets = [%c0_dst2, %c0_dst2], sizes = [%c8_dst2_0, %c8_dst2_1] : !pto.tensor_view<8x8xf32> -> !pto.partition_tensor_view<8x8xf32>
    %c0_dst3 = arith.constant 0 : index
    %c8_dst3_0 = arith.constant 8 : index
    %c8_dst3_1 = arith.constant 8 : index
    %c8_dst3_s0 = arith.constant 8 : index
    %c1_dst3_s1 = arith.constant 1 : index
    %dst3_tv = pto.make_tensor_view %dst3, shape = [%c8_dst3_0, %c8_dst3_1], strides = [%c8_dst3_s0, %c1_dst3_s1] : !pto.tensor_view<8x8xf32>
    %dst3_pt = pto.partition_view %dst3_tv, offsets = [%c0_dst3, %c0_dst3], sizes = [%c8_dst3_0, %c8_dst3_1] : !pto.tensor_view<8x8xf32> -> !pto.partition_tensor_view<8x8xf32>
    %c0 = arith.constant 0 : index
    %c8 = arith.constant 8 : index

    %tile = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tload ins(%src_pt : !pto.partition_tensor_view<16x16xf32>)
             outs(%tile : !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    %s00 = pto.subview %tile[%c0, %c0] sizes [8, 8] :
      !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %s01 = pto.subview %tile[%c0, %c8] sizes [8, 8] :
      !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %s10 = pto.subview %tile[%c8, %c0] sizes [8, 8] :
      !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %s11 = pto.subview %tile[%c8, %c8] sizes [8, 8] :
      !pto.tile_buf<loc=vec, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
      -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tstore ins(%s00 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%dst0_pt : !pto.partition_tensor_view<8x8xf32>)
    pto.tstore ins(%s01 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%dst1_pt : !pto.partition_tensor_view<8x8xf32>)
    pto.tstore ins(%s10 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%dst2_pt : !pto.partition_tensor_view<8x8xf32>)
    pto.tstore ins(%s11 : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=8, v_row=8, v_col=8, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
              outs(%dst3_pt : !pto.partition_tensor_view<8x8xf32>)
    return
  }
}

// CHECK-COUNT-4: Tile<TileType::Vec, float, 16, 16, BLayout::RowMajor, 8, 8, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null>
// CHECK-COUNT-4: TSTORE(
// CHECK-NOT: Tile<TileType::Vec, float, 8, 8, BLayout::RowMajor, 8, 8, SLayout::NoneBox, 512, PadValue::Null, CompactMode::Null>
// CHECK-NOT: copy_ubuf_to_gm_align_b32(
